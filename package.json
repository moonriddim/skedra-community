{
	"name": "skedra",
	"private": true,
	"license": "AGPL-3.0-only",
	"scripts": {
		"dev": "turbo dev",
		"dev:sdk": "pnpm --filter @skedra/react dev",
		"build": "turbo build",
		"test": "turbo test && node --test scripts/*.test.mjs",
		"lint": "node scripts/check-canvas-boundary.mjs && biome check .",
		"lint:canvas-boundary": "node scripts/check-canvas-boundary.mjs",
		"sdk:verify": "pnpm lint:canvas-boundary && pnpm --filter @skedra/canvas-core test && node --test scripts/canvas-parity.test.mjs && pnpm --filter @skedra/react test && pnpm --filter @skedra/web build",
		"analyze": "fallow",
		"analyze:fix": "fallow fix --yes",
		"format": "biome format --write .",
		"db:push": "turbo db:push",
		"db:migrate": "turbo db:push",
		"db:studio": "turbo db:studio"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"esbuild": "^0.28.1",
		"turbo": "^2.3.0",
		"typescript": "^5.7.0"
	},
	"packageManager": "pnpm@10.33.2"
}
