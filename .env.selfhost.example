# Image location published by the owner.
SKEDRA_IMAGE_REGISTRY=ghcr.io/your-github-user
SKEDRA_IMAGE_PREFIX=skedra
SKEDRA_IMAGE_TAG=latest

POSTGRES_DB=skedra
POSTGRES_USER=skedra
POSTGRES_PASSWORD=change-this-database-password

# Keep the default Docker named volume locally. On NAS systems, prefer a dataset path,
# for example: /mnt/tank/apps/skedra/postgres
SKEDRA_POSTGRES_DATA=skedra_postgres_data

# Public URLs as seen by the browser.
SKEDRA_PUBLIC_APP_URL=http://localhost:5174
SKEDRA_PUBLIC_LIBRARIES_URL=http://localhost:5175
SKEDRA_PUBLIC_API_URL=http://localhost:5174
SKEDRA_PUBLIC_REALTIME_URL=ws://localhost:5174/realtime

# open = anyone can register, invite = first user plus invite links, closed = first user only.
SKEDRA_REGISTRATION_MODE=invite

# Community library catalog. Self-hosted instances read from and submit to the central catalog.
SKEDRA_LIBRARY_CATALOG_MODE=remote
SKEDRA_LIBRARY_CATALOG_API_URL=https://libraries.skedra.xyz
SKEDRA_LIBRARY_SUBMIT_URL=https://skedra.xyz/login?redirect=%2Flibrary

# Usually leave these empty. Set only if API/WebSocket are on another public origin.
SKEDRA_PUBLIC_FRONTEND_API_URL=
SKEDRA_PUBLIC_FRONTEND_REALTIME_URL=

# Optional calls via LiveKit. These values are the server fallback; admins can
# also configure calls in Settings -> System inside the app. Use LiveKit Cloud,
# your own LiveKit deployment, or docker-compose.livekit.yml for local testing.
SKEDRA_CALLS_ENABLED=false
SKEDRA_CALL_PROVIDER=none
SKEDRA_PUBLIC_LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TOKEN_TTL_SECONDS=3600

# Generate real secrets:
# openssl rand -hex 48
SKEDRA_AUTH_SECRET=change-me-to-a-random-secret-min-32-chars
SKEDRA_DATA_ENCRYPTION_SECRET=change-me-to-a-long-random-secret-min-32-chars
