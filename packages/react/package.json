{
	"name": "@skedra/react",
	"version": "0.1.0",
	"private": false,
	"license": "MIT",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./factories": {
			"types": "./dist/factories.d.ts",
			"import": "./dist/factories.js"
		},
		"./workspace-hooks": {
			"types": "./dist/workspace-hooks.d.ts",
			"import": "./dist/workspace-hooks.js"
		},
		"./style.css": {
			"types": "./dist/style.css.d.ts",
			"default": "./dist/style.css"
		}
	},
	"files": ["dist", "README.md", "LICENSE"],
	"sideEffects": ["**/*.css"],
	"scripts": {
		"build": "vite build && tsc -p tsconfig.json --emitDeclarationOnly --outDir dist && node scripts/copy-css-assets.mjs",
		"prepack": "pnpm run build",
		"test": "pnpm run build && node --test \"scripts/*.test.mjs\""
	},
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"react": "^18.3.0 || ^19.0.0",
		"react-dom": "^18.3.0 || ^19.0.0"
	},
	"devDependencies": {
		"@skedra/canvas-core": "workspace:*",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.3.0",
		"lucide-react": "^0.460.0",
		"typescript": "^5.7.0",
		"vite": "^6.4.1"
	}
}
