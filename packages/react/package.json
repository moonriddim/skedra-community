{
	"name": "@skedra/react",
	"version": "0.1.0",
	"private": false,
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/moonriddim/skedra-community.git",
		"directory": "packages/react"
	},
	"homepage": "https://github.com/moonriddim/skedra-community/tree/main/packages/react#readme",
	"bugs": {
		"url": "https://github.com/moonriddim/skedra-community/issues"
	},
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./factories": {
			"types": "./dist/factories.d.ts",
			"import": "./dist/factories.js"
		},
		"./commands": {
			"types": "./dist/commands.d.ts",
			"import": "./dist/commands.js"
		},
		"./editor-panels": {
			"types": "./dist/editor-panels.d.ts",
			"import": "./dist/editor-panels.js"
		},
		"./io": {
			"types": "./dist/io.d.ts",
			"import": "./dist/io.js"
		},
		"./exporters": {
			"types": "./dist/exporters.d.ts",
			"import": "./dist/exporters.js"
		},
		"./workspace-hooks": {
			"types": "./dist/workspace-hooks.d.ts",
			"import": "./dist/workspace-hooks.js"
		},
		"./style.css": {
			"types": "./dist/style.css.d.ts",
			"default": "./dist/style.css"
		}
	},
	"files": ["dist", "README.md", "LICENSE"],
	"sideEffects": ["**/*.css"],
	"scripts": {
		"build": "vite build && tsc -p tsconfig.json --emitDeclarationOnly --outDir dist && node scripts/copy-css-assets.mjs",
		"dev": "node scripts/dev.mjs",
		"prepack": "pnpm run build",
		"test": "pnpm run build && node --test \"scripts/*.test.mjs\""
	},
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"react": "^18.3.0 || ^19.0.0",
		"react-dom": "^18.3.0 || ^19.0.0"
	},
	"devDependencies": {
		"@skedra/canvas-core": "workspace:*",
		"@skedra/canvas-editor": "workspace:*",
		"@skedra/canvas-io": "workspace:*",
		"@skedra/canvas-react": "workspace:*",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"@vitejs/plugin-react": "^4.3.0",
		"lucide-react": "^0.460.0",
		"typescript": "^5.7.0",
		"vite": "^6.4.1"
	}
}
