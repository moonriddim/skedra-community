{
	"name": "@skedra/canvas-editor",
	"version": "0.1.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./style.css": "./src/style.css"
	},
	"scripts": {
		"build": "tsc --declaration --emitDeclarationOnly --outDir dist",
		"test": "esbuild src/*.test.ts --bundle --platform=node --format=esm --external:react --external:react-dom --external:react-dom/* --external:lucide-react --outdir=.tmp/test-build-tests && node --test \".tmp/test-build-tests/*.js\""
	},
	"dependencies": {
		"@excalidraw/laser-pointer": "^1.3.2",
		"@skedra/canvas-core": "workspace:*",
		"lucide-react": "^0.460.0"
	},
	"peerDependencies": {
		"react": "^18.3.0 || ^19.0.0",
		"react-dom": "^18.3.0 || ^19.0.0"
	},
	"devDependencies": {
		"@types/node": "^22.10.0",
		"@types/react": "^19.0.0",
		"@types/react-dom": "^19.0.0",
		"esbuild": "^0.28.1",
		"typescript": "^5.7.0"
	}
}
