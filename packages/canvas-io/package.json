{
	"name": "@skedra/canvas-io",
	"version": "0.1.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"main": "./src/index.ts",
	"types": "./src/index.ts",
	"exports": {
		".": "./src/index.ts",
		"./codecs": "./src/codecs.ts",
		"./exporters": "./src/exporters.ts",
		"./file": "./src/file.ts",
		"./file-schema": "./src/file-schema.ts"
	},
	"scripts": {
		"build": "tsc --declaration --emitDeclarationOnly --outDir dist",
		"test": "esbuild src/*.test.ts --bundle --platform=node --format=esm --outdir=.tmp/test-build-tests && node --test \".tmp/test-build-tests/*.js\""
	},
	"dependencies": {
		"@skedra/canvas-core": "workspace:*",
		"zod": "^3.24.0"
	},
	"devDependencies": {
		"typescript": "^5.7.0"
	}
}
