# Skedra – Standalone Whiteboard

APP_URL=http://localhost:5174
API_URL=http://localhost:3001
# Öffentlicher Bibliotheks-Katalog — eigene App (apps/libraries), Port 5175
LIBRARIES_URL=http://localhost:5175
# Web-App: Link zum Katalog
VITE_LIBRARIES_URL=http://localhost:5175
# Katalog-App (apps/libraries) — siehe apps/libraries/.env.example
SKEDRA_DEPLOYMENT_MODE=selfhost
SKEDRA_REGISTRATION_MODE=invite
SKEDRA_LIBRARY_CATALOG_MODE=local
SKEDRA_LIBRARY_CATALOG_API_URL=
SKEDRA_LIBRARY_SUBMIT_URL=

# Optional calls via LiveKit. These values are the server fallback; admins can
# also configure calls in Settings -> System inside the app.
SKEDRA_CALLS_ENABLED=false
SKEDRA_CALL_PROVIDER=none
SKEDRA_PUBLIC_LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_TOKEN_TTL_SECONDS=3600

# Optional S3-compatible image storage. Image bytes are encrypted in the browser
# before upload. R2 uses region=auto. Managed/SaaS deployments require S3 storage.
SKEDRA_OBJECT_STORAGE_PROVIDER=inline
SKEDRA_OBJECT_STORAGE_PRESET=custom
SKEDRA_OBJECT_STORAGE_ENDPOINT=
SKEDRA_OBJECT_STORAGE_REGION=
SKEDRA_OBJECT_STORAGE_BUCKET=
SKEDRA_OBJECT_STORAGE_ACCESS_KEY_ID=
SKEDRA_OBJECT_STORAGE_SECRET_ACCESS_KEY=
SKEDRA_OBJECT_STORAGE_PUBLIC_BASE_URL=
SKEDRA_OBJECT_STORAGE_FORCE_PATH_STYLE=false
SKEDRA_ASSET_MAX_IMAGE_BYTES=8388608

# Cloudflare R2 example:
# SKEDRA_OBJECT_STORAGE_PROVIDER=s3
# SKEDRA_OBJECT_STORAGE_PRESET=r2
# SKEDRA_OBJECT_STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
# SKEDRA_OBJECT_STORAGE_REGION=auto
# SKEDRA_OBJECT_STORAGE_BUCKET=skedra-assets

# Local dev fallback with docker-compose.livekit.yml:
# SKEDRA_CALLS_ENABLED=true
# SKEDRA_CALL_PROVIDER=livekit
# SKEDRA_PUBLIC_LIVEKIT_URL=ws://localhost:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret

# MCP Server (apps/mcp)
SKEDRA_API_URL=http://localhost:3001/api/v1
SKEDRA_API_KEY=

# Optional: Plattform-AI-Fallback (wenn User keinen BYOK-Key hat)
# SKEDRA_AI_API_KEY=local-only
# SKEDRA_AI_PROVIDER=ollama
# SKEDRA_AI_MODEL=llama3.2
# SKEDRA_AI_BASE_URL=http://127.0.0.1:11434/v1/chat/completions

DATABASE_URL=postgresql://skedra:skedra_secret@localhost:5434/skedra

AUTH_SECRET=change-me-to-a-random-secret-min-32-chars
DATA_ENCRYPTION_SECRET=change-me-to-a-long-random-secret-min-32-chars

# Optional: SMTP-Fallback aus der Server-Umgebung (wenn nicht in den System-Einstellungen gesetzt)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=Skedra <noreply@example.com>
# SMTP_SECURE=false
