# Skedra – Standalone Whiteboard

APP_URL=http://localhost:5174
API_URL=http://localhost:3001
# Serverintern fuer Remote-MCP-Tools; nicht als Browser-URL verwenden.
MCP_INTERNAL_API_URL=http://127.0.0.1:3001/api/v1
# Optionaler lokaler Regressionstest (API muss laufen):
# MCP_E2E_BASE_URL=http://localhost:3001
# MCP_E2E_USER_ID=first
SKEDRA_REGISTRATION_MODE=invite

DATABASE_URL=postgresql://skedra:skedra_secret@localhost:5434/skedra

# PostgreSQL pool and server-side query guards (per API instance).
DATABASE_POOL_MAX=10
DATABASE_IDLE_TIMEOUT_SECONDS=30
DATABASE_CONNECT_TIMEOUT_SECONDS=10
DATABASE_MAX_LIFETIME_SECONDS=1800
DATABASE_STATEMENT_TIMEOUT_MS=30000
DATABASE_IDLE_IN_TRANSACTION_TIMEOUT_MS=30000

# Unbedingt durch zufaellige Werte ersetzen. DATA_ENCRYPTION_SECRET schuetzt
# unter anderem gespeicherte Profilbilder mit AES-256-GCM.
AUTH_SECRET=change-me-to-a-random-secret-min-32-chars
DATA_ENCRYPTION_SECRET=change-me-to-a-long-random-secret-min-32-chars

# Optional Better Auth social login providers.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=