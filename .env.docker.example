# Copy this file to .env.docker on your server and adjust the values.

POSTGRES_DB=skedra
POSTGRES_USER=skedra
POSTGRES_PASSWORD=change-this-database-password

# Keep the default Docker named volume locally. On TrueNAS, prefer a dataset path,
# for example: /mnt/tank/apps/skedra/postgres
SKEDRA_POSTGRES_DATA=skedra_postgres_data

# Public URLs as seen by the browser. If you put Skedra behind a reverse proxy,
# use your real https URLs here.
SKEDRA_PUBLIC_APP_URL=http://localhost:5174

# open = anyone can register, invite = first user plus invite links, closed = first user only.
SKEDRA_REGISTRATION_MODE=invite

# Host ports exposed by docker compose.
SKEDRA_WEB_PORT=5174

# Generate real secrets for production, for example:
# node -e "console.log(require('node:crypto').randomBytes(48).toString('hex'))"
SKEDRA_AUTH_SECRET=change-me-to-a-random-secret-min-32-chars
SKEDRA_DATA_ENCRYPTION_SECRET=change-me-to-a-long-random-secret-min-32-chars
